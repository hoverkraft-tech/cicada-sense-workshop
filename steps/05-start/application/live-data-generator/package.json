{
  "name": "@cicada-sense/live-data-generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "dev": "npm run dev:backend & npm run dev:frontend",
    "dev:backend": "tsx src/backend/main.ts",
    "dev:frontend": "vite --host 0.0.0.0 --port 5174",
    "lint": "biome lint --config-path ${BIOME_CONFIG_PATH:-../biome.json} src",
    "lint:fix": "biome check --config-path ${BIOME_CONFIG_PATH:-../biome.json} --write src",
    "lint:ci": "biome lint --config-path ${BIOME_CONFIG_PATH:-../biome.json} --error-on-warnings src --reporter=sarif | tee biome-report.sarif",
    "preview": "vite preview --host 0.0.0.0 --port 5174",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=default --reporter=junit --outputFile=junit.xml --coverage.enabled --coverage.reporter=lcov --coverage.reporter=text",
    "test:e2e": "playwright test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "allowScripts": {
    "@nestjs/core@11.1.24": true,
    "esbuild@0.28.1": true
  }
}
