[codespell]
# Skip third-party/generated paths and French-locale content files.
ignore-words-list = afterAll,vEw
skip =
    ".git",
    "*.svg",
    "**/package-lock.json",
    "**/application/*/dist/**",
    "**/application/*/node_modules/**",
    "**/application/*/coverage/**",
    "**/application/*/junit.xml",
    "**/charts/dist/**"
