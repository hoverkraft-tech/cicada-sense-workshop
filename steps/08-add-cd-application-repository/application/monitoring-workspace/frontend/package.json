{
  "name": "@cicada-sense/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "dev": "vite --host 0.0.0.0",
    "lint": "biome lint --config-path ${BIOME_CONFIG_PATH:-../../biome.json} src",
    "lint:fix": "biome check --config-path ${BIOME_CONFIG_PATH:-../../biome.json} --write src",
    "lint:ci": "biome lint --config-path ${BIOME_CONFIG_PATH:-../../biome.json} --error-on-warnings src --reporter=sarif | tee biome-report.sarif",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=default --reporter=junit --outputFile=junit.xml --coverage.enabled --coverage.reporter=lcov --coverage.reporter=text",
    "test:e2e": "playwright test",
    "test:e2e:live": "LOCAL_UID=$(id -u) LOCAL_GID=$(id -g) COMPOSE_DOCKER_CLI_BUILD=1 DOCKER_BUILDKIT=1 docker compose -f ../../../compose.yaml up -d --wait postgres redis && playwright test -c playwright.live.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@deck.gl/aggregation-layers": "^9.3.5",
    "@deck.gl/core": "^9.3.5",
    "@deck.gl/layers": "^9.3.5",
    "@deck.gl/mapbox": "^9.3.5",
    "@tanstack/react-query": "^5.101.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "i18next": "^26.3.3",
    "lucide-react": "^1.21.0",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.9.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "ws": "8.21.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
